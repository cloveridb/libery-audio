# ================================================
# LiberyAudio Simple — Environment Variables
# Copy file ini ke .env dan isi nilainya
# ================================================

# Secret untuk session (buat string random panjang)
SESSION_SECRET=ganti-ini-dengan-random-string-panjang

# Key enkripsi API Key Roblox — HARUS TEPAT 32 KARAKTER
ENCRYPT_KEY=12345678901234567890123456789012

# Secret untuk buat akun admin pertama
ADMIN_SEED_SECRET=seed-libery-2024

# Port server (default: 3000)
PORT=3000
